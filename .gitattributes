# Force LF for scripts and Linux assets — CRLF breaks shebangs on Linux.
* text=auto

*.sh        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.policy    text eol=lf
*.desktop   text eol=lf
*.md        text eol=lf
dsms-gui    text eol=lf
update-from-github.sh text eol=lf
