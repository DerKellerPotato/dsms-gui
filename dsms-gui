#!/usr/bin/env python3
"""DSMS Control Center — GTK desktop app for DSMS.

Edits /etc/dsms/dsms.conf through a form UI, applies the configuration,
runs the domain join, and imports/exports configuration files. Runs as a
normal user; privileged operations go through pkexec -> /usr/local/bin/dsms.

Dependencies: python3-gi, gir1.2-gtk-3.0 (preinstalled on Mint/Ubuntu).
"""

import os
import re
import shutil
import sys
import tempfile

import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, GLib, Gio  # noqa: E402

SELF_DIR = os.path.dirname(os.path.abspath(__file__))
CONF_PATH = "/etc/dsms/dsms.conf"
# Config-field template shipped by the 'dsms' package (this app depends on it).
TEMPLATE_PATHS = ["/etc/dsms/dsms.conf.example"]
DSMS_BIN = shutil.which("dsms") or "/usr/local/bin/dsms"


def dsms_installed():
    """True when the dsms CLI is present (the GUI drives it for every action)."""
    return shutil.which("dsms") is not None or os.path.exists("/usr/local/bin/dsms")


